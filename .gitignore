# ABB RobotStudio GitIgnore File
# 此文件用于排除不需要版本控制的临时文件和本地配置文件

# ============================================
# RobotStudio 临时文件和缓存
# ============================================
*.tmp
*.temp
*.bak
*.backup
*.log

# RobotStudio 自动保存和恢复文件
*.rsautosave
*.rsrecovery

# ============================================
# 编译和构建输出
# ============================================
*.dll
*.exe
*.pdb
*.cache

# ============================================
# 本地用户配置和许可证文件
# ============================================
# 许可证文件（包含敏感信息）
*.rlf
key.id
program.id

# 本地控制器配置
controller.rsf
system.guid
template.guid

# ============================================
# 系统内部文件
# ============================================
# 内部生成的二进制文件
*.bin
ctrl.bin
image.bin

# 数据库文件
*.db
Registry.db
netconfig.db

# XML 注册表文件
*_registry.xml

# ============================================
# 备份文件夹内容（保留结构，排除内容）
# ============================================
Backups/*/BACKINFO/
Backups/*/HOME/user.sys
Backups/*/RAPID/
Backups/*/SYSPAR/
Backups/*/system.xml

# ============================================
# Systems 文件夹中的内部文件
# ============================================
Systems/*/INTERNAL/
Systems/*/PRODUCTS/

# ============================================
# IDE 和编辑器文件
# ============================================
# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code
.vscode/
*.code-workspace

# ============================================
# 操作系统文件
# ============================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ============================================
# 其他
# ============================================
# 压缩包
*.zip
*.rar
*.7z

# 允许保留的文件类型
!*.rsstn
!*.rssln
!*.rslib
!*.mod
!*.cfg
!*.sys
!*.txt
